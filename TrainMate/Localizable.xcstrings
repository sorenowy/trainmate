    "app.onboarding.description.one" : {
      "comment" : "Description text for the first page of the onboarding flow.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schluss mit der Trainingsplanung auf dem winzigen Display der Uhr. Plane ganz entspannt auf dem iPhone und iPad."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stop struggling with workout builders on a tiny watch face. Plan comfortably on iPhone and iPad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fini la corvée de créer des séances sur le petit écran de la montre. Planifiez confortablement sur iPhone et iPad."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Koniec z układaniem treningów na małym ekranie zegarka. Planuj wygodnie na iPhonie i iPadzie."
          }
        }
      }
    },
    "app.onboarding.description.three" : {
      "comment" : "Description for the last screen in the onboarding flow.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Pläne arbeiten nahtlos mit der Apple Watch und HealthKit zusammen. Lass dein Handy im Spind, schnall die Uhr um und starte dein Training."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your plans sync seamlessly with Apple Watch and HealthKit. Leave your phone in the locker, strap in, and hit your session."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos programmes s'intègrent parfaitement à l'Apple Watch et HealthKit. Laissez votre téléphone au vestiaire, ajustez votre bracelet et lancez votre séance."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Twoje plany bezszwowo współpracują z Apple Watch i HealthKit. Zostaw telefon w szafce, zepnij pasek i ruszaj na trening."
          }
        }
      }
    },
    "app.onboarding.description.two" : {
      "comment" : "Description text for the second page of the onboarding flow.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufwärmen, Belastungsphasen, Regeneration. Erstelle komplexe strukturierte Workouts wie Lego-Steine – auf die Sekunde genau."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warm-ups, work sets, recovery. Build complex structured workouts like Lego bricks with second-by-second precision."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Échauffement, blocs d’effort, récupération. Assemblez des entraînements structurés complexes comme des Lego, avec une précision à la seconde près."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Rozgrzewka, bloki pracy, regeneracja. Układaj złożone treningi strukturalne jak klocki Lego, z precyzją co do sekundy."
          }
        }
      }
    },
